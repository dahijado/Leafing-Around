{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/avisoLegal/?$",
			"dest": "_render"
		},
		{
			"src": "^/coleccion/?$",
			"dest": "_render"
		},
		{
			"src": "^/criatura/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/criaturasMarinas/?$",
			"dest": "_render"
		},
		{
			"src": "^/insectos/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/peces/?$",
			"dest": "_render"
		},
		{
			"src": "^/registro/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}