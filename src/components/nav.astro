---
import { supabase } from '../lib/supabase'

const currentPath = Astro.url.pathname;
const path = currentPath.replace(/\/$/, "");

const esPez = path.startsWith("/peces") || path.startsWith("/criatura/fish-");
const esCriaturaMarina = path.startsWith("/criaturasMarinas") || path.startsWith("/criatura/sea-");
const esInsecto = path.startsWith("/insectos") || path.startsWith("/criatura/bug-");

const esLogin = path === "/login";
const esColeccion = path === "/coleccion";

const accessToken = Astro.cookies.get("sb-access-token")?.value;
const refreshToken = Astro.cookies.get("sb-refresh-token")?.value;

if (accessToken && refreshToken) {
  await supabase.auth.setSession({
    access_token: accessToken,
    refresh_token: refreshToken,
  });
}

const { data: { user } } = await supabase.auth.getUser();
---

<div class="nav">
  <nav class="header-nav">
    <ul class="nav-links">
      <li><a href="/peces" class={esPez ? "activo" : ""}>Fish</a></li>
      <li><a href="/criaturasMarinas" class={esCriaturaMarina ? "activo" : ""}>Sea Creatures</a></li>
      <li><a href="/insectos" class={esInsecto ? "activo" : ""}>Bugs</a></li>
    </ul>

    <ul class="links-usuario">
      {!user && (
        <li><a href="/login" class={esLogin ? "activo" : ""}>Login</a></li>
      )}

      {user && (
        <li class="user-actions">
          <a href="/coleccion" class={esColeccion ? "activo" : ""}>My Collection</a>
          <span class="pipe">|</span>
          <form action="/api/logout" method="POST" class="logout-form">
            <button type="submit" class="logout-btn">Logout</button>
          </form>
        </li>
      )}
    </ul>
  </nav>
</div>

<style>
  .nav {
    background: #C49A6C;
    position: relative;
    padding: 0.2rem 0;
    border-top: 4px solid #8B633E;
  }

  .nav::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 8px;
    background: linear-gradient(to bottom, #8B633E 0%, #9A724B 100%);
  }

  .header-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .nav-links {
    grid-column: 2;
    display: flex;
    gap: 2.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .links-usuario {
    grid-column: 3;
    display: flex;
    justify-self: end;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .user-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem; /* Ajustado para que estén pegados */
  }

  .pipe {
    color: #2E2A27;
    font-size: 1.35rem;
    font-weight: 300;
  }

  .header-nav a, .logout-btn {
    text-decoration: none;
    color: #2E2A27;
    font-family: "Fredoka", sans-serif;
    font-weight: 500;
    font-size: 1.35rem;
    padding: 0.4rem 0.6rem;
    cursor: pointer;
    background: none;
    border: none;
    transition: transform 0.25s ease-in-out;
    display: inline-block;
  }

  .header-nav a:hover, .logout-btn:hover {
    transform: scale(1.12);
  }

  .header-nav a.activo {
    color: white;
    border-bottom: 3px solid #2E2A27;
    padding-bottom: 0.10rem;
  }

  @media (max-width: 950px) {
    .header-nav {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1rem;
      padding: 1rem;
    }
    .nav-links { grid-column: 1; justify-content: center; gap: 1.5rem; }
    .links-usuario { grid-column: 1; justify-self: center; }
  }

  @media (max-width: 600px) {
    .nav-links { gap: 0.8rem; font-size: 1.1rem; }
    .header-nav a, .logout-btn { font-size: 1.1rem; }
    .pipe { font-size: 1.1rem; }
  }
</style>

<script>
  const logoutForm = document.querySelector('.logout-form');
  if (logoutForm) {
    logoutForm.addEventListener('submit', () => {
      localStorage.clear();
      sessionStorage.clear();
      window.addEventListener('unload', () => location.reload());
    });
  }
</script>