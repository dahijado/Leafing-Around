---

---
<aside class="sidebar">
  <div class="card">
    <h2>Filtros</h2>

    <section class="group">
      <h3>Hemisferio</h3>
      <button onclick="setFiltro('hemisferio', 'todos')">Todos</button>
      <button onclick="setFiltro('hemisferio', 'norte')">Norte</button>
      <button onclick="setFiltro('hemisferio', 'sur')">Sur</button>
    </section>

    <section class="group">
      <h3>Mes</h3>
      <select onchange="setFiltro('mes', this.value)">
        <option value="todos">Todos</option>
        <option value="enero">Enero</option>
        <option value="febrero">Febrero</option>
        <option value="marzo">Marzo</option>
        <option value="abril">Abril</option>
        <option value="mayo">Mayo</option>
        <option value="junio">Junio</option>
        <option value="julio">Julio</option>
        <option value="agosto">Agosto</option>
        <option value="septiembre">Septiembre</option>
        <option value="octubre">Octubre</option>
        <option value="noviembre">Noviembre</option>
        <option value="diciembre">Diciembre</option>
      </select>
    </section>

    <section class="group">
      <h3>Hora del día</h3>
      <button onclick="setFiltro('hora', 'todos')">Todas</button>
      <button onclick="setFiltro('hora', 'manana')">Mañana</button>
      <button onclick="setFiltro('hora', 'tarde')">Tarde</button>
      <button onclick="setFiltro('hora', 'noche')">Noche</button>
    </section>

    <button class="reset" onclick="resetFiltros()">Reset</button>
  </div>
</aside>

<style>
    .sidebar {
        width: 260px;
        padding: 1rem;
        position: sticky;
        top: 1rem;
        height: fit-content;
        z-index: 10;
        background: #F6F1E8;
    }

    .card {
        background: #F6F1E8;
        border: 3px solid rgba(0, 0, 0, 0.5);
        box-shadow: 0 0 30px rgba(0, 0, 0, 0.1);
        border-radius: 16px;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    h2 {
        margin: 0;
        font-size: 1.1rem;
    }

    h3 {
        margin: 0.5rem 0;
        font-size: 0.9rem;
    }

    .group {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        font-family: "Fredoka", sans-serif;
        font-weight: 500;
    }

    button {
        padding: 0.4rem;
        border: 1px solid rgba(0, 0, 0, 0.4);
        background: white;
        cursor: pointer;
        transition: 0.2s ease;
        border-radius: 10px;
    }

    button:hover {
        background: #E8DDCF;
    }

    select {
        padding: 0.4rem;
        border: 1px solid rgba(0, 0, 0, 0.4);
        background: white;
    }

    .reset {
        margin-top: 0.5rem;
        background: #333;
        color: white;
        border: none;
    }

    @media (max-width: 900px) {
        .sidebar {
            width: 100%;
            position: relative;
            top: 0;
        }

        .card {
            flex-direction: column;
        }

        .group {
            width: 100%;
        }

        .reset {
            width: 100%;
        }
    }
</style>