---

---
<aside class="sidebar">
  <div class="sidebar-card">
    <h2>Filtros</h2>

    <section class="group">
      <h3>Hemisferio</h3>
      <button data-filtro data-tipo="hemisferio" data-valor="todos">Todos</button>
      <button data-filtro data-tipo="hemisferio" data-valor="north">Norte</button>
      <button data-filtro data-tipo="hemisferio" data-valor="south">Sur</button>
    </section>

    <section class="group">
      <h3>Mes</h3>
      <select data-filtro data-tipo="mes" data-valor="mes">
        <option value="todos">Todos</option>
        <option value="1">Enero</option>
        <option value="2">Febrero</option>
        <option value="3">Marzo</option>
        <option value="4">Abril</option>
        <option value="5">Mayo</option>
        <option value="6">Junio</option>
        <option value="7">Julio</option>
        <option value="8">Agosto</option>
        <option value="9">Septiembre</option>
        <option value="10">Octubre</option>
        <option value="11">Noviembre</option>
        <option value="12">Diciembre</option>
      </select>
    </section>

    <section class="group">
      <h3>Hora del día</h3>
      <button data-filtro data-tipo="hora" data-valor="todos">Todas</button>
      <button data-filtro data-tipo="hora" data-valor="manana">Mañana</button>
      <button data-filtro data-tipo="hora" data-valor="tarde">Tarde</button>
      <button data-filtro data-tipo="hora" data-valor="noche">Noche</button>
    </section>

    <button class="reset" data-reset>Reset</button>
  </div>
</aside>

<style>
    .sidebar {
        width: 260px;
        padding: 1rem;
        position: sticky;
        top: 1rem;
        height: fit-content;
        z-index: 10;
        background: #F6F1E8;
    }

    .sidebar-card {
        background: #F6F1E8;
        border: 3px solid rgba(0, 0, 0, 0.5);
        box-shadow: 0 0 30px rgba(0, 0, 0, 0.1);
        border-radius: 16px;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    h2 {
        margin: 0;
        font-size: 1.1rem;
    }

    h3 {
        margin: 0.5rem 0;
        font-size: 0.9rem;
    }

    .group {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        font-family: "Fredoka", sans-serif;
        font-weight: 500;
    }

    .sidebar button {
        padding: 0.4rem;
        border: 1px solid rgba(0, 0, 0, 0.4);
        background: white;
        cursor: pointer;
        border-radius: 10px;
        transition: 0.2s ease;
        color: black;
    }

    .sidebar button:hover:not(.activo):not(.reset) {
        background: #E8DDCF;
    }

    .sidebar select {
        padding: 0.4rem;
        border: 1px solid rgba(0, 0, 0, 0.4);
        background: white;
        border-radius: 10px;
    }

    .sidebar .activo {
        background: #2E2A27;
        color: white;
        border-color: #2E2A27;
    }

    .sidebar .reset {
        margin-top: 0.5rem;
        background: #2E2A27;
        color: white;
        border: none;
    }

    @media (max-width: 900px) {
    .sidebar {
        width: 100%;
        position: relative;
        top: 0;
        }
    }
    .sidebar-card {
        flex-direction: column;
    }

    .group {
        width: 100%;
    }

    .reset {
        width: 100%;
    }
</style>