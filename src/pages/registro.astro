---
import Layout from '../layouts/Layout.astro';
import Header from '../components/header.astro';
import Nav from '../components/nav.astro';
import Footer from '../components/footer.astro';
import { createServerSupabase } from '../lib/supabase-server';

let errorMessage = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get("email")?.toString();
    const password = formData.get("password")?.toString();

    if (email && password) {
      const supabase = createServerSupabase(Astro.cookies);
      
      const { error } = await supabase.auth.signUp({ 
        email, 
        password 
      });
      
      if (error) {
        errorMessage = error.message;
      } else {
        return Astro.redirect("/coleccion");
      }
    }
  } catch (e) {
    console.error("Error en registro:", e);
    errorMessage = "An unexpected error occurred.";
  }
}
---

<Layout title="Leafing Around - Register">

<Header />
<Nav />

<main class="contenedor-centrado">

  <section class="carta contenedor-formulario">
    <h1 class="bienvenida">Create your Account</h1>
    <p class="subtitulo">Sign up to start tracking your personal museum collection!</p>

    {errorMessage && (
      <div class="caja-error">
        <p>{errorMessage}</p>
      </div>
    )}
    
    <form method="POST" class="formulario-autenticacion">
      <div class="grupo-formulario">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" placeholder="mail@example.com" required />
      </div>

      <div class="grupo-formulario">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Password" required />
      </div>

      <button type="submit" class="boton-envio">Register Account</button>
    </form>

    <div class="enlace-login">
      <p>Already have an account? <a href="/login">Log in here</a></p>
    </div>
  </section>

</main>

<Footer />
</Layout>

<style>
    .contenedor-centrado {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex: 1;
        padding: 1.25rem;
        background: transparent;
    }

    .carta {
        width: 100%;
        max-width: 600px;
        background: #F5F0D8;
        border-radius: 24px;
        padding: 2rem 2.5rem;
        border: 3px solid rgba(0,0,0,0.3);
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        font-family: "Fredoka", sans-serif;
        color: #2E2A27;
        line-height: 1.7;
    }

    .bienvenida {
        font-size: 1.6rem;
        font-weight: 600;
        text-align: center;
        margin-bottom: 0.25rem;
    }

    .subtitulo {
        font-size: 1rem;
        font-weight: 400;
        text-align: center;
        opacity: 0.8;
        margin-bottom: 2rem;
    }

    .caja-error {
        background: #F8D7DA;
        border: 2px solid #D9534F;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        margin-bottom: 1.5rem;
        color: #A94442;
        font-size: 0.95rem;
        text-align: center;
    }

    .formulario-autenticacion {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .grupo-formulario {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .grupo-formulario label {
        font-size: 1.05rem;
        font-weight: 500;
    }

    .grupo-formulario input {
        font-family: "Fredoka", sans-serif;
        font-size: 1rem;
        padding: 0.75rem 1rem;
        border-radius: 14px;
        border: 2px solid rgba(0, 0, 0, 0.2);
        background: #FFF;
        color: #2E2A27;
        outline: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .grupo-formulario input:focus {
        border-color: #8B633E;
        box-shadow: 0 0 0 3px rgba(139, 99, 62, 0.15);
    }

    .boton-envio {
        font-family: "Fredoka", sans-serif;
        font-size: 1.15rem;
        font-weight: 600;
        color: #FFF;
        background: #8B633E;
        border: 2px solid rgba(0, 0, 0, 0.2);
        border-radius: 14px;
        padding: 0.85rem;
        cursor: pointer;
        margin-top: 0.5rem;
        box-shadow: 0 4px 0px rgba(0, 0, 0, 0.15);
        transition: transform 0.1s ease, background-color 0.2s ease, box-shadow 0.1s ease;
    }

    .boton-envio:hover {
        background: #9A724B;
    }

    .boton-envio:active {
        transform: translateY(3px);
        box-shadow: 0 1px 0px rgba(0, 0, 0, 0.15);
    }

    .enlace-login {
        text-align: center;
        margin-top: 1.75rem;
        font-size: 0.95rem;
    }

    .enlace-login a {
        color: #8B633E;
        text-decoration: none;
        font-weight: 500;
        border-bottom: 2px solid transparent;
        transition: border-color 0.2s;
    }

    .enlace-login a:hover {
        border-color: #8B633E;
    }

    @media (max-width: 480px) {
        .carta {
            padding: 1.5rem 1.25rem;
        }
    }
</style>