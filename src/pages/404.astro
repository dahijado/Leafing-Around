---
import Layout from "../layouts/Layout.astro";
import Header from "@/components/header.astro";
import Nav from "@/components/nav.astro";
import { Button } from "@/components/starwind/button";
import Footer from "@/components/footer.astro";
import { Image } from 'astro:assets';
import blathersError from '../assets/Blathers error.png';
---

<Layout title="Leafing Around - Not Found">
    <Header />
    <Nav />
    <div class="fondo-404">
        <h1>404 - Not Found</h1>
        <Image class="img-error" src={blathersError} alt="blathersError" quality={100} format="png"/>
        <p class="p-error">¡Uhu! No puede ser... ¡No encuentro la página!</p>
        <Button class="boton  bg-taupe-700 hover:bg-taupe-800" href="/" variant="info" size="md">Volver</Button>
    </div>
    <Footer />
</Layout>


<style>
    .fondo-404 {
        background-color: #F6F1E8;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    h1{
        margin: 20px;
        font-size: 2.5rem;
        font-family: "Fredoka", sans-serif;
        font-weight: bolder;
        color: #2E2A27;
    }

    .boton{
        font-family: "Fredoka", sans-serif;
        font-weight: 400;
        color: white;
    }

    .img-error {
        left: 1rem;
        top: 50%;
        left: 50%;
        height: 13rem;
        width: auto;
    }

    .p-error {
        margin: 20px;
        font-family: "Fredoka",sans-serif;
        font-weight: 500;
        color: #2E2A27;;
    }
</style>
