---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/header.astro';
import Nav from '../../components/nav.astro';
import Footer from '../../components/footer.astro';

import {
  getTodasCriaturas,
  ordenarCriaturas
} from '../../lib/funciones.js';

export async function getStaticPaths() {
  const todas = ordenarCriaturas(await getTodasCriaturas());

  return todas.map((criatura) => {

    const mismoTipo = todas.filter(
      (c) => c.type === criatura.type
    );

    const index = mismoTipo.findIndex(
      (c) => c.slug === criatura.slug
    );

    return {
      params: { slug: criatura.slug },
      props: {
        criatura,
        anterior: mismoTipo[index - 1] ?? null,
        siguiente: mismoTipo[index + 1] ?? null,
      }
    };
  });
}

const { criatura, anterior, siguiente } = Astro.props;

const meses = [
  "JAN", "FEB", "MAR", "APR",
  "MAY", "JUN", "JUL", "AUG",
  "SEP", "OCT", "NOV", "DEC"
];

const volverHref =
  criatura.type === "fish"
    ? "/peces"
    : criatura.type === "bug"
    ? "/insectos"
    : "/criaturasMarinas";
---

<Layout title={`Leafing Around - ${criatura.name}`}>

  <Header />
  <Nav />

  <main class="detalle-container">

    <div class="detalle-card">

      <div class="top-bar">

        <div class="nav-izquierda">
          {anterior ? (
            <a class="nav-link" href={`/criatura/${anterior.slug}`}>
                <span class="flecha">←</span>
                <img src={anterior.image_url} class="nav-icono" alt={anterior.name}/>
                {anterior.name}
            </a>
          ) : <span></span>}
        </div>

        <div class="nav-centro">
          <a class="volver" href={volverHref}>
            Back to {
              criatura.type === "fish"
                ? "Fish"
                : criatura.type === "bug"
                ? "Bugs"
                : "Sea Creatures"
            }
          </a>
        </div>

        <div class="nav-derecha">
          {siguiente ? (
            <a class="nav-link" href={`/criatura/${siguiente.slug}`}>
            {siguiente.name}
            <img src={siguiente.image_url} class="nav-icono" alt={siguiente.name}/>
            <span class="flecha">→</span>
            </a>
          ) : <span></span>}
        </div>

      </div>

      <img
        src={criatura.render_url}
        alt={criatura.name}
        class="imagen"
      />

      <h1>{criatura.name}</h1>

      <p class="tipo">
        {criatura.type === "fish" && "Fish"}
        {criatura.type === "bug" && "Bug"}
        {criatura.type === "sea_creature" && "Sea Creature"}
      </p>

      <div class="stats-grid">

        <div class="dato">
          <span class="label">Price</span>
          <span class="valor">{criatura.sell_nook}</span>
        </div>

        {criatura.rarity && (
          <div class="dato">
            <span class="label">Rarity</span>
            <span class="valor">{criatura.rarity}</span>
          </div>
        )}

        {criatura.location && (
          <div class="dato">
            <span class="label">Location</span>
            <span class="valor">{criatura.location}</span>
          </div>
        )}

        {criatura.shadow_size && (
          <div class="dato">
            <span class="label">Shadow</span>
            <span class="valor">{criatura.shadow_size}</span>
          </div>
        )}

      </div>

      {criatura.north && (
        <section class="meses-section">

          <h2>Northern Hemisphere</h2>

          <div class="mes-grid">
            {meses.map((mes, index) => {
              const disponible =
                criatura.north.months_array.includes(index + 1);

              return (
                <div class={`mes ${disponible ? "activo" : ""}`}>
                  {mes}
                </div>
              );
            })}
          </div>

        </section>
      )}

      {criatura.south && (
        <section class="meses-section">

          <h2>Southern Hemisphere</h2>

          <div class="mes-grid">
            {meses.map((mes, index) => {
              const disponible =
                criatura.south.months_array.includes(index + 1);

              return (
                <div class={`mes ${disponible ? "activo" : ""}`}>
                  {mes}
                </div>
              );
            })}
          </div>

        </section>
      )}

      {criatura.catchphrases?.[0] && (
        <blockquote class="frase">
          "{criatura.catchphrases[0]}"
        </blockquote>
      )}

    </div>
  </main>

  <Footer />
</Layout>

<style>
  .detalle-container {
    display: flex;
    justify-content: center;
    padding: 1.25rem;
  }

  .detalle-card {
    width: 100%;
    max-width: 1100px;
    background: #F5F0D8;
    border-radius: 24px;
    padding: 1.5rem 2rem;
    border: 3px solid rgba(0,0,0,0.3);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    font-family: "Fredoka", sans-serif;
  }

  .top-bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    margin-bottom: 2rem;
  }

  .nav-izquierda {
    justify-self: start;
  }

  .nav-centro {
    justify-self: center;
  }

  .nav-derecha {
    justify-self: end;
  }
  
    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: #2E2A27;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        padding: 0.4rem 0.6rem;
        border-radius: 10px;
        transition: background 0.2s ease, transform 0.2s ease;
    }

    .nav-link:hover {
        background: rgba(0,0,0,0.05);
        transform: translateY(-1px);
    }

    .volver {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #2E2A27;
        text-decoration: none;
        font-size: 1.2rem;
        font-weight: 800;
        padding: 0.6rem 1rem;
        background: rgba(210, 200, 185, 0.45);
        border: 2px solid rgba(160, 150, 140, 0.35);
        border-radius: 12px;
        transition: background 0.2s ease, transform 0.2s ease;
    }

    .volver:hover {
        background: rgba(210, 200, 185, 0.45);
        transform: scale(1.05);
    }

  .nav-icono {
    width: 3rem;
    height: 3rem;
    object-fit: contain;
  }

  .flecha {
    font-size: 1.4rem;
    font-weight: 900;
    color: #2E2A27;
    display: inline-block;
    transform: translateY(-1px);
  }

  .imagen {
    display: block;
    width: 14rem;
    max-width: 100%;
    height: auto;
    margin: 0 auto 1.5rem;
    object-fit: contain;
  }

  h1 {
    text-align: center;
    font-size: 2.4rem;
    font-weight: 500;
    color: #2E2A27;
    margin-bottom: 0.2rem;
  }

  .tipo {
    text-align: center;
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .dato {
    background: white;
    border-radius: 14px;
    padding: 0.8rem;
    text-align: center;
    border: 2px solid rgba(0,0,0,0.06);
  }

  .label {
    display: block;
    font-size: 0.8rem;
    opacity: 0.7;
    margin-bottom: 0.3rem;
  }

  .valor {
    font-size: 1rem;
    font-weight: 600;
  }

  .meses-section {
    margin-top: 1.2rem;
  }

  .meses-section h2 {
    margin-bottom: 0.6rem;
    font-size: 1rem;
    color: #2E2A27;
  }

  .mes-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 0.3rem;
  }

  .mes {
    padding: 0.35rem 0;
    border-radius: 8px;
    background: #D8CEBA;
    text-align: center;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .mes.activo {
    background: #6DBF73;
    color: white;
  }

  .frase {
    margin-top: 1.5rem;
    background: #FFF7E8;
    border-left: 6px solid #6DBF73;
    padding: 1rem;
    border-radius: 14px;
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .top-bar {
      grid-template-columns: 1fr;
      gap: 0.8rem;
      text-align: center;
    }

    .nav-left,
    .nav-center,
    .nav-right {
      justify-self: center;
    }
  }
</style>